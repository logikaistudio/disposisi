{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "rewrites": [
    {
      "source": "/((?!api/|assets/|vite.svg|manifest.webmanifest).*)",
      "destination": "/index.html"
    }
  ]
}